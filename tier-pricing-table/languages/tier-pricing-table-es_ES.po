#: src/Addons/GlobalTieredPricing/CPT/Form/Tabs/ProductAndCategories.php:23
msgid "Applies to products"
msgstr "Se aplica a productos"

#: src/Addons/GlobalTieredPricing/CPT/Form/Tabs/ProductAndCategories.php:26
