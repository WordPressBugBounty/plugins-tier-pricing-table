"],"Tax Class":["\u041d\u0430\u043b\u043e\u0433\u043e\u0432\u044b\u0439 \u043a\u043b\u0430\u0441\u0441"],"Default (Inherit)":["\u041f\u043e \u0443\u043c\u043e\u043b\u0447\u0430\u043d\u0438\u044e (\u043d\u0430\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u044c)"],"Reduced Rate":["\u0421\u043d\u0438\u0436\u0435\u043d\u043d\u0430\u044f \u0441\u0442\u0430\u0432\u043a\u0430"],"Zero Rate":["\u041d\u0443\u043b\u0435\u0432\u0430\u044f \u0441\u0442\u0430\u0432\u043a\u0430"],"Prices Entered With Tax":["\u0426\u0435\u043d\u044b \u0443\u043a\u0430\u0437\u0430\u043d\u044b \u0441 \u043d\u0430\u043b\u043e\u0433\u043e\u043c"],"Yes, I will enter prices inclusive of tax":["\u0414\u0430, \u044f \u0443\u043a\u0430\u0436\u0443 \u0446\u0435\u043d\u044b \u0441 \u0443\u0447\u0435\u0442\u043e\u043c \u043d\u0430\u043b\u043e\u0433\u043e\u0432"],"No, I will enter prices exclusive of tax":["\u041d\u0435\u0442, \u044f \u0431\u0443\u0434\u0443 \u0432\u0432\u043e\u0434\u0438\u0442\u044c \u0446\u0435\u043d\u044b \u0431\u0435\u0437 \u043d\u0430\u043b\u043e\u0433\u0430"],"Display Prices in Shop":["\u041e\u0442\u043e\u0431\u0440\u0430\u0437\u0438\u0442\u044c \u0446\u0435\u043d\u044b \u0432 \u043c\u0430\u0433\u0430\u0437\u0438\u043d\u0435"],"Including Tax":["\u0412\u043a\u043b\u044e\u0447\u0430\u044f \u043d\u0430\u043b\u043e\u0433"],"Excluding Tax":["\u0411\u0435\u0437 \u0443\u0447\u0435\u0442\u0430 \u043d\u0430\u043b\u043e\u0433\u0430"],"Display Prices in Cart\/Checkout":["\u041e\u0442\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u0435 \u0446\u0435\u043d \u0432 \u043a\u043e\u0440\u0437\u0438\u043d\u0435\/\u043e\u0444\u043e\u0440\u043c\u043b\u0435\u043d\u0438\u0438 \u0437\u0430\u043a\u0430\u0437\u0430"],"Price Display Suffix":["\u0421\u0443\u0444\u0444\u0438\u043a\u0441 \u043e\u0442\u043e\u0431\u0440\u0430\u0436\u0435\u043d\u0438\u044f \u0446\u0435\u043d\u044b"],"Leave blank to inherit default settings.":["\u041e\u0441\u0442\u0430\u0432\u044c\u0442\u0435 \u043f\u0443\u0441\u0442\u044b\u043c, \u0447\u0442\u043e\u0431\u044b \u0443\u043d\u0430\u0441\u043b\u0435\u0434\u043e\u0432\u0430\u0442\u044c \u043d\u0430\u0441\u0442\u0440\u043e\u0439\u043a\u0438 \u043f\u043e \u0443\u043c\u043e\u043b\u0447\u0430\u043d\u0438\u044e."],"Remove Configuration":["\u0423\u0434\u0430\u043b\u0438\u0442\u044c \u043a\u043e\u043d\u0444\u0438\u0433\u0443\u0440\u0430\u0446\u0438\u044e"],"Add Configuration":["\u0414\u043e\u0431\u0430\u0432\u0438\u0442\u044c \u043a\u043e\u043d\u0444\u0438\u0433\u0443\u0440\u0430\u0446\u0438\u044e"]}}}