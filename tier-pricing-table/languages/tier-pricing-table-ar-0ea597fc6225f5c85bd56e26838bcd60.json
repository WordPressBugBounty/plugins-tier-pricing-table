{"translation-revision-date":"YEAR-MO-DA HO:MI+ZONE","generator":"WP-CLI\/2.12.0","source":"src\/Addons\/Tools\/js-source\/components\/CleanupTool.js","domain":"messages","locale_data":{"messages":{"":{"domain":"messages","lang":"ar","plural-forms":"nplurals=2; plural=(n != 1);"},"Item added":["\u062a\u0645\u062a \u0625\u0636\u0627\u0641\u0629 \u0627\u0644\u0639\u0646\u0635\u0631"],"Item removed":["\u062a\u0645\u062a \u0625\u0632\u0627\u0644\u0629 \u0627\u0644\u0639\u0646\u0635\u0631"],"Remove item":["\u0625\u0632\u0627\u0644\u0629 \u0627\u0644\u0639\u0646\u0635\u0631"],"Clean Up & Reset Options":["\u062e\u064a\u0627\u0631\u0627\u062a \u0627\u0644\u062a\u0646\u0638\u064a\u0641 \u0648\u0625\u0639\u0627\u062f\u0629 \u0627\u0644\u0636\u0628\u0637"],"Warning:":["\u062a\u062d\u0630\u064a\u0631:"],"The actions below will permanently delete data from your database. Please make a backup before proceeding.":["\u0633\u062a\u0624\u062f\u064a \u0627\u0644\u0625\u062c\u0631\u0627\u0621\u0627\u062a \u0627\u0644\u0645\u0648\u0636\u062d\u0629 \u0623\u062f\u0646\u0627\u0647 \u0625\u0644\u0649 \u062d\u0630\u0641 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0645\u0646 \u0642\u0627\u0639\u062f\u0629 \u0628\u064a\u0627\u0646\u0627\u062a\u0643 \u0646\u0647\u0627\u0626\u064a\u064b\u0627. \u064a\u0631\u062c\u0649 \u0639\u0645\u0644 \u0646\u0633\u062e\u0629 \u0627\u062d\u062a\u064a\u0627\u0637\u064a\u0629 \u0642\u0628\u0644 \u0627\u0644\u0645\u062a\u0627\u0628\u0639\u0629."],"1. Product Level Data":["1. \u0628\u064a\u0627\u0646\u0627\u062a \u0645\u0633\u062a\u0648\u0649 \u0627\u0644\u0645\u0646\u062a\u062c"],"Remove tiered pricing rules directly attached to individual products.":["\u0642\u0645 \u0628\u0625\u0632\u0627\u0644\u0629 \u0642\u0648\u0627\u0639\u062f \u0627\u0644\u062a\u0633\u0639\u064a\u0631 \u0627\u0644\u0645\u062a\u062f\u0631\u062c\u0629 \u0627\u0644\u0645\u0631\u062a\u0628\u0637\u0629 \u0645\u0628\u0627\u0634\u0631\u0629 \u0628\u0627\u0644\u0645\u0646\u062a\u062c\u0627\u062a \u0627\u0644\u0641\u0631\u062f\u064a\u0629."],"Clean Standard Tiered Pricing Data":["\u062a\u0646\u0638\u064a\u0641 \u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u062a\u0633\u0639\u064a\u0631 \u0627\u0644\u0642\u064a\u0627\u0633\u064a\u0629 \u0627\u0644\u0645\u062a\u062f\u0631\u062c\u0629"],"Role Based Data":["\u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0642\u0627\u0626\u0645\u0629 \u0639\u0644\u0649 \u0627\u0644\u062f\u0648\u0631"],"Filters (Optional)":["\u0627\u0644\u0645\u0631\u0634\u062d\u0627\u062a (\u0627\u062e\u062a\u064a\u0627\u0631\u064a)"],"Leave blank to apply the cleanup to all products. Otherwise, select specific categories or products.":["\u0627\u062a\u0631\u0643\u0647 \u0641\u0627\u0631\u063a\u064b\u0627 \u0644\u062a\u0637\u0628\u064a\u0642 \u0639\u0645\u0644\u064a\u0629 \u0627\u0644\u062a\u0646\u0638\u064a\u0641 \u0639\u0644\u0649 \u0643\u0627\u0641\u0629 \u0627\u0644\u0645\u0646\u062a\u062c\u0627\u062a. \u0628\u062e\u0644\u0627\u0641 \u0630\u0644\u0643\u060c \u062d\u062f\u062f \u0641\u0626\u0627\u062a \u0623\u0648 \u0645\u0646\u062a\u062c\u0627\u062a \u0645\u062d\u062f\u062f\u0629."],"Select Categories":["\u062d\u062f\u062f \u0627\u0644\u0641\u0626\u0627\u062a"],"Select Products":["\u062d\u062f\u062f \u0627\u0644\u0645\u0646\u062a\u062c\u0627\u062a"],"2. Global Pricing Rules":["2. \u0642\u0648\u0627\u0639\u062f \u0627\u0644\u062a\u0633\u0639\u064a\u0631 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0629"],"Global pricing rules apply to multiple products at once.":["\u062a\u0646\u0637\u0628\u0642 \u0642\u0648\u0627\u0639\u062f \u0627\u0644\u062a\u0633\u0639\u064a\u0631 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0629 \u0639\u0644\u0649 \u0645\u0646\u062a\u062c\u0627\u062a \u0645\u062a\u0639\u062f\u062f\u0629 \u0641\u064a \u0648\u0642\u062a \u0648\u0627\u062d\u062f."],"Delete all Global Pricing Rules":["\u062d\u0630\u0641 \u062c\u0645\u064a\u0639 \u0642\u0648\u0627\u0639\u062f \u0627\u0644\u062a\u0633\u0639\u064a\u0631 \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0629"],"3. Plugin Settings":["3. \u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0644\u0645\u0633\u0627\u0639\u062f"],"Reset general settings, labels, and table column configurations.":["\u0625\u0639\u0627\u062f\u0629 \u062a\u0639\u064a\u064a\u0646 \u0627\u0644\u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0639\u0627\u0645\u0629 \u0648\u0627\u0644\u062a\u0633\u0645\u064a\u0627\u062a \u0648\u062a\u0643\u0648\u064a\u0646\u0627\u062a \u0623\u0639\u0645\u062f\u0629 \u0627\u0644\u062c\u062f\u0648\u0644."],"Reset all plugin settings to defaults":["\u0625\u0639\u0627\u062f\u0629 \u062a\u0639\u064a\u064a\u0646 \u0643\u0627\u0641\u0629 \u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0628\u0631\u0646\u0627\u0645\u062c \u0627\u0644\u0645\u0633\u0627\u0639\u062f \u0625\u0644\u0649 \u0627\u0644\u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0627\u0644\u0627\u0641\u062a\u0631\u0627\u0636\u064a\u0629"],"Are you sure you want to delete the selected data? This action cannot be undone.":["\u0647\u0644 \u0623\u0646\u062a \u0645\u062a\u0623\u0643\u062f \u0623\u0646\u0643 \u062a\u0631\u064a\u062f \u062d\u0630\u0641 \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0645\u062d\u062f\u062f\u0629\u061f \u0644\u0627 \u064a\u0645\u0643\u0646 \u0627\u0644\u062a\u0631\u0627\u062c\u0639 \u0639\u0646 \u0647\u0630\u0627 \u0627\u0644\u0625\u062c\u0631\u0627\u0621."],"Product data cleaned up.":["\u062a\u0645 \u062a\u0646\u0638\u064a\u0641 \u0628\u064a\u0627\u0646\u0627\u062a \u0627\u0644\u0645\u0646\u062a\u062c."],"Global rules deleted.":["\u062a\u0645 \u062d\u0630\u0641 \u0627\u0644\u0642\u0648\u0627\u0639\u062f \u0627\u0644\u0639\u0627\u0644\u0645\u064a\u0629."],"Settings reset to default.":["\u0625\u0639\u0627\u062f\u0629 \u0636\u0628\u0637 \u0627\u0644\u0625\u0639\u062f\u0627\u062f\u0627\u062a \u0639\u0644\u0649 \u0627\u0644\u0648\u0636\u0639 \u0627\u0644\u0627\u0641\u062a\u0631